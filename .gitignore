# Root gitignore for PostCrossing mock project

# Node dependencies
node_modules/
**/node_modules/

# Environment files (keep examples committed)
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Logs and diagnostics
logs/
**/logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Caches and temporary files
.tmp/
.temp/
.cache/
**/.tmp/
**/.temp/
**/.cache/

# Build and output folders
dist/
build/
out/
coverage/
.nyc_output/

# OS-generated files
.DS_Store
Thumbs.db

# Editor/IDE settings
.vscode/
.idea/
*.swp
*.swo

# Local data/config that shouldn't be committed
*.local.json
**/*.local.json

# Firefox extension artifacts (if you zip for upload)
extension/*.zip
