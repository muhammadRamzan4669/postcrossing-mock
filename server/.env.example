# PostCrossing Mock Server — .env example
# Copy this file to ".env" in the same directory and adjust values as needed.

# Node environment: development | production | test
NODE_ENV=development

# MongoDB connection string
# Local default: requires a running mongod on localhost:27017
MONGODB_URI=mongodb://localhost:27017/postcrossing_mock

# HTTP port the Express server will listen on
PORT=4000

# CORS configuration
# Use "*" for demos/local testing, or set to a specific origin (e.g., http://localhost:5173)
CORS_ORIGIN=*
